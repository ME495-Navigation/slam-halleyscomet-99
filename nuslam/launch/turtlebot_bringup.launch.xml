<?xml version="1.0"?>
<launch>
  <!-- LiDAR driver: publishes /scan from the physical LIDAR sensor -->
  <node pkg="hls_lfcd_lds_driver" exec="hlds_laser_publisher"
        name="hlds_laser_publisher">
    <param name="port" value="/dev/ttyUSB0"/>
    <param name="frame_id" value="blue/base_scan"/>
  </node>

  <!-- Hardware interface -->
  <node pkg="numsr_turtlebot" exec="numsr_turtlebot" name="numsr_turtlebot"/>

  <!-- Turtle control -->
  <node pkg="nuturtle_control" exec="turtle_control" name="turtle_control">
    <param from="$(find-pkg-share nuturtle_description)/config/diff_params.yaml"/>
    <remap from="joint_states" to="blue/joint_states"/>
  </node>

  <!-- Blue robot state publisher -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="blue_rsp">
    <param name="robot_description"
           value="$(command 'xacro $(find-pkg-share nuturtle_description)/urdf/turtlebot3_burger.urdf.xacro color:=blue')"/>
    <param name="frame_prefix" value="blue/"/>
    <remap from="joint_states" to="blue/joint_states"/>
    <remap from="robot_description" to="blue/robot_description"/>
  </node>
</launch>