<?xml version="1.0"?>
<launch>
  <arg name="robot" default="nusim" description="Options: nusim, localhost, or turtlebot name" />
  <arg name="cmd_src" default="teleop" description="Options: circle, teleop, or none" />
  <arg name="use_rviz" default="true" description="Launch RViz2 if true" />

  <node pkg="nuslam" exec="slam" name="slam" output="screen">
    <param from="$(find-pkg-share nuturtle_description)/config/diff_params.yaml" />
    <param name="body_id" value="green/base_footprint" />
    <param name="odom_id" value="odom" />
    <param name="map_id" value="map" />
    <remap from="/red/joint_states" to="/red/joint_states" />
  </node>

  <node pkg="robot_state_publisher" exec="robot_state_publisher" name="green_rsp">
    <param name="robot_description" value="$(command 'xacro $(find-pkg-share nuturtle_description)/urdf/turtlebot3_burger.urdf.xacro color:=green')" />
    <param name="frame_prefix" value="green/" />
    <remap from="robot_description" to="green/robot_description" />
    <remap from="joint_states" to="green/joint_states" />
  </node>

  <group if="$(eval '\'$(var robot)\' == \'nusim\'')">
    <include file="$(find-pkg-share nuturtle_control)/launch/start_robot.launch.xml">
      <arg name="cmd_src" value="$(var cmd_src)" />
      <arg name="robot" value="nusim" />
      <arg name="use_rviz" value="false" />
    </include>
  </group>

  <node pkg="tf2_ros" exec="static_transform_publisher" name="map_to_world"
        args="--frame-id map --child-frame-id nusim/world" />

  <node pkg="rviz2" exec="rviz2" name="rviz2" 
        args="-d $(find-pkg-share nuslam)/config/nuslam_sim.rviz"
        if="$(var use_rviz)" />

</launch>