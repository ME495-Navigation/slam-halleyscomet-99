<?xml version="1.0"?>
<launch>
  <arg name="use_rviz" default="true" description="Launch RViz2 to visualize the robots."/>

  <group>
    <push-ros-namespace namespace="red"/>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
      <arg name="color" value="red"/>
      <arg name="use_rviz" value="false"/>
      <arg name="use_jsp" value="true"/>
    </include>
  </group>

  <group>
    <push-ros-namespace namespace="green"/>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
      <arg name="color" value="green"/>
      <arg name="use_rviz" value="false"/>
      <arg name="use_jsp" value="true"/>
    </include>
  </group>

  <group>
    <push-ros-namespace namespace="blue"/>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
      <arg name="color" value="blue"/>
      <arg name="use_rviz" value="false"/>
      <arg name="use_jsp" value="true"/>
    </include>
  </group>

  <group>
    <push-ros-namespace namespace="purple"/>
    <include file="$(find-pkg-share nuturtle_description)/launch/load_one.launch.xml">
      <arg name="color" value="purple"/>
      <arg name="use_rviz" value="false"/>
      <arg name="use_jsp" value="true"/>
    </include>
  </group>

  <node pkg="tf2_ros" exec="static_transform_publisher" name="red_tf" 
        args="--x 0.25 --y 0 --z 0 --yaw 0 --pitch 0 --roll 0 --frame-id nusim/world --child-frame-id red/base_footprint" />
  <node pkg="tf2_ros" exec="static_transform_publisher" name="green_tf" 
        args="--x 0 --y 0.5 --z 0 --yaw 0 --pitch 0 --roll 0 --frame-id nusim/world --child-frame-id green/base_footprint" />
  <node pkg="tf2_ros" exec="static_transform_publisher" name="blue_tf" 
        args="--x -0.5 --y 0 --z 0 --yaw 0 --pitch 0 --roll 0 --frame-id nusim/world --child-frame-id blue/base_footprint" />
  <node pkg="tf2_ros" exec="static_transform_publisher" name="purple_tf" 
        args="--x 0 --y -1.0 --z 0 --yaw 0 --pitch 0 --roll 0 --frame-id nusim/world --child-frame-id purple/base_footprint" />

  <node pkg="rviz2" exec="rviz2" name="rviz2" 
        args="-d $(find-pkg-share nuturtle_description)/config/basic_all.rviz"
        if="$(var use_rviz)" />
</launch>