<launch>
    <arg name="use_rviz" default="true" />
    <arg name="use_jsp" default="true" />

    <let name="urdf_path" 
         value="$(find-pkg-share nuturtle_description)/urdf/turtlebot3_burger.urdf.xacro" />
    
    <node pkg="robot_state_publisher" exec="robot_state_publisher" name="robot_state_publisher">
        <param name="robot_description" value="$(command 'xacro $(var urdf_path)')" />
    </node>

    <group if="$(var use_jsp)">
        <node pkg="joint_state_publisher" exec="joint_state_publisher" name="joint_state_publisher" />
    </group>

    <group if="$(var use_rviz)">
        <node pkg="rviz2" exec="rviz2" name="rviz2" 
              args="-d $(find-pkg-share nuturtle_description)/config/load_one.rviz"
              on_exit="shutdown" />
    </group>
</launch>